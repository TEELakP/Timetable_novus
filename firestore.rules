/**
 * SMART TIMETABLE MANAGER - SECURITY POLICY
 * 
 * CORE PHILOSOPHY
 * This ruleset implements a centralized administrative control model. Access is bifurcated 
 * between 'Administrators' who manage the master data (Teachers, Units, Rules) and the 
 * schedule generation, and 'Viewers' (authenticated users) who can consume the finalized 
 * scheduling output.
 * 
 * DATA STRUCTURE
 * - Master Data: /teachers, /academicUnits, and /schedulingRules are top-level collections.
 * - Scheduling: /timetables is a top-level collection containing the schedule metadata.
 * - Details: /timetables/{id}/classSessions is a subcollection containing the individual 
 *   scheduled events.
 * 
 * KEY SECURITY DECISIONS
 * - Administrative RBAC: All write operations across all collections are restricted to users 
 *   identified as administrators. This is verified against an /admins/ collection.
 * - Authorization Independence (QAP): ClassSession documents denormalize the 'status' of 
 *   their parent Timetable (timetableStatus). This allows the 'list' rule for sessions 
 *   to check visibility permissions without performing a get() on the parent Timetable.
 * - Prototyping Flexibility: Rules enforce strict ownership and relational integrity for 
 *   IDs, but do not restrict the specific fields or data types of content to allow 
 *   for rapid iterative development.
 * - Public/Private Segregation: Scheduling rules and draft timetables are hidden from 
 *   non-admin users to protect institutional logic and prevent confusion from 
 *   incomplete schedules.
 * 
 * DENORMALIZATION FOR AUTHORIZATION
 * - ClassSession documents MUST contain 'timetableStatus' and 'timetableId' to ensure 
 *   performant and secure list queries.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user has administrative privileges. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    /** @description Checks if the document exists and the user is an admin. */
    function isExistingAdmin() {
      return resource != null && isAdmin();
    }

    /** @description Validates that the internal ID of a new document matches its path ID. */
    function isIdConsistent(id) {
      return request.resource.data.id == id;
    }

    // --- COLLECTION RULES ---

    /** 
     * @description Rules for Teacher profiles. Publicly readable by signed-in users, managed by admins.
     * @path /teachers/{teacherId}
     * @allow (get/list) if signed in.
     * @allow (create/update/delete) if user is an administrator.
     * @deny (create) if the internal 'id' does not match the URL parameter.
     * @principle Administrative control for institutional master data.
     */
    match /teachers/{teacherId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin() && isIdConsistent(teacherId);
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /** 
     * @description Rules for Academic Units (courses). Publicly readable by signed-in users.
     * @path /academicUnits/{unitId}
     * @allow (get/list) if signed in.
     * @allow (create) if admin and internal id matches.
     * @principle Structural integrity via ID consistency and admin-only writes.
     */
    match /academicUnits/{unitId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin() && isIdConsistent(unitId);
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /** 
     * @description Rules for internal Scheduling Logic. Restricted to administrators only.
     * @path /schedulingRules/{ruleId}
     * @allow (all) only if user is an administrator.
     * @deny (get/list) for standard authenticated users to protect proprietary logic.
     * @principle Strict isolation of system configuration data.
     */
    match /schedulingRules/{ruleId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && isIdConsistent(ruleId);
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /** 
     * @description Rules for Timetables. Admins have full access; users can only see 'PUBLISHED' schedules.
     * @path /timetables/{timetableId}
     * @allow (get/list) if admin OR if timetable status is 'PUBLISHED'.
     * @allow (write) if user is an administrator.
     * @principle Explicit state modeling (DRAFT/PUBLISHED) governs read access.
     */
    match /timetables/{timetableId} {
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.status == 'PUBLISHED');
      allow create: if isAdmin() && isIdConsistent(timetableId);
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();

      /** 
       * @description Rules for Class Sessions nested under Timetables.
       * @path /timetables/{timetableId}/classSessions/{sessionId}
       * @allow (get/list) if admin OR if denormalized timetableStatus is 'PUBLISHED'.
       * @principle Authorization Independence: Uses denormalized status to avoid parent lookups.
       */
      match /classSessions/{sessionId} {
        allow get, list: if isAdmin() || (isSignedIn() && resource.data.timetableStatus == 'PUBLISHED');
        allow create: if isAdmin() && isIdConsistent(sessionId) && request.resource.data.timetableId == timetableId;
        allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id && request.resource.data.timetableId == resource.data.timetableId;
        allow delete: if isExistingAdmin();
      }
    }

    /**
     * @description Placeholder for the administrative role mapping. 
     * @path /admins/{uid}
     * @principle RBAC source of truth.
     */
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via server-side/admin SDK only.
    }
  }
}