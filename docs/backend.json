
{
  "entities": {
    "Teacher": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Teacher",
      "type": "object",
      "description": "Represents a teacher with their profile, qualifications for teaching specific units, and defined availability.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Teacher entity."
        },
        "name": {
          "type": "string",
          "description": "The full name of the teacher."
        },
        "email": {
          "type": "string",
          "description": "The email address of the teacher.",
          "format": "email"
        },
        "qualifiesForUnitIds": {
          "type": "array",
          "description": "References to AcademicUnit entities that this teacher is qualified to teach.",
          "items": {
            "type": "string"
          }
        },
        "unavailableTimeSlots": {
          "type": "array",
          "description": "A list of recurring weekly time slots when the teacher is explicitly unavailable.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "name",
        "qualifiesForUnitIds"
      ]
    },
    "AcademicUnit": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AcademicUnit",
      "type": "object",
      "description": "Represents an academic course or unit offered by the institution.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the AcademicUnit entity."
        },
        "name": {
          "type": "string",
          "description": "The full name of the academic unit."
        },
        "code": {
          "type": "string",
          "description": "A short alphanumeric code for the unit."
        },
        "unitType": {
          "type": "string",
          "description": "The classification of the unit (theory/practical)."
        },
        "recommendedDurationHours": {
          "type": "number",
          "description": "Recommended hours per session."
        }
      },
      "required": [
        "id",
        "name",
        "unitType"
      ]
    },
    "Room": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Room",
      "type": "object",
      "description": "Represents a physical or virtual room where class sessions are held.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Room entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the room (e.g., 'Room 301', 'Lab A')."
        },
        "capacity": {
          "type": "number",
          "description": "The maximum number of students the room can accommodate."
        },
        "campus": {
          "type": "string",
          "description": "The campus where the room is located (Ultimo, Gosford, Perth, Online)."
        }
      },
      "required": [
        "id",
        "name",
        "capacity",
        "campus"
      ]
    },
    "SchedulingRule": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SchedulingRule",
      "type": "object",
      "description": "A constraint or rule that the AI generator must follow when creating a timetable.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "description": "The text content of the rule."
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "ClassSession": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ClassSession",
      "type": "object",
      "description": "Represents a single scheduled instance of an academic unit.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the ClassSession entity."
        },
        "timetableId": {
          "type": "string",
          "description": "Reference to the Timetable."
        },
        "academicUnitId": {
          "type": "string",
          "description": "Reference to the AcademicUnit."
        },
        "teacherId": {
          "type": "string",
          "description": "Reference to the Teacher."
        },
        "scheduledStartTime": {
          "type": "string",
          "format": "date-time"
        },
        "scheduledEndTime": {
          "type": "string",
          "format": "date-time"
        },
        "location": {
          "type": "string",
          "description": "The room name or location."
        },
        "isConflict": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "timetableId",
        "academicUnitId",
        "teacherId",
        "scheduledStartTime",
        "scheduledEndTime",
        "location",
        "isConflict"
      ]
    },
    "Timetable": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Timetable",
      "type": "object",
      "description": "Represents a complete generated or manually adjusted timetable.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "status"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/teachers/{teacherId}",
        "definition": {
          "entityName": "Teacher",
          "schema": {
            "$ref": "#/backend/entities/Teacher"
          },
          "description": "Stores individual teacher profiles."
        }
      },
      {
        "path": "/academicUnits/{unitId}",
        "definition": {
          "entityName": "AcademicUnit",
          "schema": {
            "$ref": "#/backend/entities/AcademicUnit"
          },
          "description": "Contains definitions for all academic units."
        }
      },
      {
        "path": "/rooms/{roomId}",
        "definition": {
          "entityName": "Room",
          "schema": {
            "$ref": "#/backend/entities/Room"
          },
          "description": "Stores room definitions and capacities."
        }
      },
      {
        "path": "/schedulingRules/{ruleId}",
        "definition": {
          "entityName": "SchedulingRule",
          "schema": {
            "$ref": "#/backend/entities/SchedulingRule"
          },
          "description": "Stores custom scheduling constraints for the AI."
        }
      },
      {
        "path": "/timetables/{timetableId}",
        "definition": {
          "entityName": "Timetable",
          "schema": {
            "$ref": "#/backend/entities/Timetable"
          },
          "description": "Represents a complete timetable."
        }
      },
      {
        "path": "/timetables/{timetableId}/classSessions/{classSessionId}",
        "definition": {
          "entityName": "ClassSession",
          "schema": {
            "$ref": "#/backend/entities/ClassSession"
          },
          "description": "Represents individual class sessions."
        }
      }
    ]
  }
}
